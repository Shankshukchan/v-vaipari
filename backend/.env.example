# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# Local:      postgresql://user:password@localhost:5432/kirana_db
# Supabase:   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/kirana_db"

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-strong-random-secret"
JWT_EXPIRES_IN="7d"

# ── Frontend ─────────────────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS="http://localhost:5173"

# ── File Uploads (Cloudinary) ─────────────────────────────────────────────────
# Optional — only needed for logo/signature upload feature
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
